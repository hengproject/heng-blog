---
import { Button } from '@/components/user'
import BlogStats from '@/components/home/BlogStats.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import config from '@/site-config'
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB966'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-4 text-center' id='content-header'>
      <div class='grid size-24 place-items-center rounded-lg border bg-muted text-3xl font-bold'>
        {(config.author_en ?? config.author).slice(0, 1)}
      </div>
      <div>
        <h1 class='text-3xl font-bold'>{config.title}</h1>
        <p class='mt-2 text-muted-foreground'>{config.description_en}</p>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='Start writing'>
        <p class='text-muted-foreground'>
          This starter is ready for your content. Add Markdown or MDX posts under
          <code>src/content/blog</code> and customize the site settings when you are ready.
        </p>
        <Button title='Browse posts' class='w-fit self-end' href='/en/blog/all' style='ahead' />
      </Section>
      <Section title='Statistics'>
        <BlogStats />
      </Section>
    </div>
  </main>
</PageLayout>
