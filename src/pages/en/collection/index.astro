---
import { getBlogCollectionEn, getCollectionPostsByKey, getSidebarCollections } from '@/server'

import PageLayout from '@/layouts/BaseLayout.astro'
import CollectionPreview from '@/components/pages/CollectionPreview.astro'
import { Button, Icon } from '@/components/user'

const allPosts = await getBlogCollectionEn()
const collections = await getSidebarCollections(allPosts, 'en')

const collectionsWithCover = await Promise.all(
  collections.map(async (collection) => {
    const posts = await getCollectionPostsByKey(allPosts, collection.key)
    return {
      ...collection,
      coverImage: posts[0]?.data.heroImage
    }
  })
)

const meta = {
  description: 'All blog collections and series',
  title: 'All Collections'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/en' style='back' />
  <main class='mt-6 lg:mt-10'>
    <div class='mb-6 flex items-center gap-2'>
      <Icon name='package' class='size-5' />
      <h1 class='text-3xl font-medium'>Collections</h1>
    </div>

    {
      collectionsWithCover.length === 0 ? (
        <p class='text-muted-foreground'>No collections yet.</p>
      ) : (
        <ul class='grid grid-cols-1 gap-4 text-start md:grid-cols-2'>
          {collectionsWithCover.map((collection) => (
            <CollectionPreview {collection} locale='en' />
          ))}
        </ul>
      )
    }
  </main>
</PageLayout>
