---
import type { GetStaticPaths } from 'astro'

import { getCategoryPageData } from '@/utils/category-pages'
import { getBlogCollection } from '@/server'

import CategoryPage from '@/components/blog/CategoryPage.astro'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const categoryPages = getCategoryPageData(await getBlogCollection(), 'zh')

  return categoryPages.flatMap(({ posts, props }) =>
    paginate(posts, {
      params: { category: props.category },
      pageSize: config.content?.blogPageSize || 8,
      props
    })
  )
}) satisfies GetStaticPaths
---

<CategoryPage locale='zh' {...Astro.props} />
