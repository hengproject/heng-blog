---
import { Image } from 'astro:assets'
import { getSiteIdentity, getTranslations, type Locale } from '@/i18n'

import CommonPage from '@/layouts/CommonPage.astro'
import { Card, Icon, Label } from '@/components/user'
import avatar from '@/assets/avatar.png'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const text = getTranslations(locale)
const { author, description } = getSiteIdentity(locale)
---

<CommonPage title={text.about.title}>
  <div class='not-prose flex flex-col gap-10'>
    <section class='flex flex-col gap-5 sm:flex-row sm:items-center'>
      <Image
        src={avatar}
        alt={`${author}: ${text.about.avatarAlt}`}
        class='size-24 shrink-0 rounded-lg border object-cover p-1'
        loading='eager'
      />
      <div class='flex flex-col gap-3'>
        <div>
          <h2 class='text-2xl font-semibold'>{author}</h2>
          <p class='mt-1 text-muted-foreground'>{description}</p>
        </div>
        <div class='flex flex-wrap gap-2'>
          <Label title={text.about.location}>
            <Icon name='location' class='size-4' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href='https://github.com' target='_blank'>
            <Icon name='github' class='size-4' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <section class='grid gap-4 md:grid-cols-2'>
      <Card heading={text.about.profile} subheading={text.about.profileDescription} />
      <Card heading={text.about.focus} subheading={text.about.focusDescription} />
    </section>
  </div>
</CommonPage>
