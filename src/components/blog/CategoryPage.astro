---
import type { Page } from 'astro'
import { getTranslations, type Locale } from '@/i18n'
import type { BlogEntry, SidebarCollection } from '@/server'

import PageLayout from '@/layouts/BaseLayout.astro'
import { Paginator, PostPreview } from '@/components/pages'
import { Button, Icon } from '@/components/user'

interface Props {
  locale: Locale
  page: Page<BlogEntry>
  uniqueTags: string[]
  sidebarCollections: SidebarCollection[]
  hasMoreCollections: boolean
  collectionsCount: number
  category: string
  prevCategory: string
  nextCategory: string
  categoryMap: Record<string, string>
}

const {
  locale,
  page,
  uniqueTags,
  sidebarCollections,
  hasMoreCollections,
  collectionsCount,
  category,
  prevCategory,
  nextCategory,
  categoryMap
} = Astro.props

const text = getTranslations(locale)
const prefix = locale === 'en' ? '/en' : ''
const categoryDisplayName = categoryMap[category] || category
const meta = {
  description: `${text.blog.categoryDescription}${categoryDisplayName}`,
  title: `${categoryDisplayName} - ${text.blog.title}`
}
---

<PageLayout {meta}>
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <div class='mb-6 mt-6 sm:mt-10'>
        <h1 class='inline-block text-3xl font-medium'>{categoryDisplayName}</h1>
        <div class='ml-3 inline-flex gap-1 align-middle'>
          <a
            href={`${prefix}/blog/${prevCategory}`}
            class='flex size-8 items-center justify-center transition-colors hover:text-primary'
            title={`${text.blog.previous}: ${categoryMap[prevCategory]}`}
            aria-label={`${text.blog.goTo} ${categoryMap[prevCategory]}`}
          >
            <Icon name='up' class='size-5' />
          </a>
          <a
            href={`${prefix}/blog/${nextCategory}`}
            class='flex size-8 items-center justify-center transition-colors hover:text-primary'
            title={`${text.blog.next}: ${categoryMap[nextCategory]}`}
            aria-label={`${text.blog.goTo} ${categoryMap[nextCategory]}`}
          >
            <Icon name='chevron-down' class='size-5' />
          </a>
        </div>
      </div>
    </div>

    {
      page.data.length === 0 ? (
        <p>{text.blog.empty}</p>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section aria-label={text.blog.postList} class='animate' id='content'>
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>
                {text.blog.page} {page.currentPage} {text.blog.showing} {page.data.length}{' '}
                {text.blog.of} {collectionsCount} {text.blog.posts}
              </span>
              <a aria-label={text.blog.viewByYear} href={`${prefix}/archives`} data-astro-prefetch>
                {text.blog.viewByYear} →
              </a>
            </div>

            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <PostPreview {post} detailed />
              ))}
            </ul>
            <Paginator currentPage={page.currentPage} lastPage={page.lastPage} url={page.url} />
          </section>

          {(!!uniqueTags.length || !!sidebarCollections.length) && (
            <aside class='animate' id='sidebar'>
              {!!sidebarCollections.length && (
                <div class='mb-8'>
                  <h2 class='mb-4 flex items-center text-lg font-semibold'>
                    <Icon name='package' class='me-2' />
                    {text.blog.collections}
                  </h2>
                  <ul class='flex flex-col gap-3'>
                    {sidebarCollections.map((collection) => (
                      <li>
                        <a
                          href={collection.href}
                          class='group block rounded-lg border border-border bg-muted/40 p-3 transition-colors hover:border-foreground/20 hover:bg-muted'
                          data-astro-prefetch
                        >
                          <p class='flex items-center justify-between text-sm font-medium text-foreground'>
                            <span>{collection.title}</span>
                            <span class='rounded-full border border-border px-2 py-0.5 text-xs text-muted-foreground'>
                              {collection.count}
                            </span>
                          </p>
                          <p class='mt-1 text-xs text-muted-foreground'>{collection.description}</p>
                        </a>
                      </li>
                    ))}
                  </ul>
                  {hasMoreCollections && (
                    <span class='mt-4 block text-end text-sm'>
                      <a
                        aria-label={text.blog.viewAllCollections}
                        href={`${prefix}/collection`}
                        data-astro-prefetch
                      >
                        {text.blog.viewAllCollections} →
                      </a>
                    </span>
                  )}
                </div>
              )}

              {!!uniqueTags.length && (
                <>
                  <h2 class='mb-4 flex items-center text-lg font-semibold'>
                    <Icon name='tag-2' class='me-2' />
                    {text.blog.tags}
                  </h2>
                  <ul class='text-bgColor flex flex-wrap gap-2'>
                    {uniqueTags.map((tag) => (
                      <li>
                        <Button title={tag} href={`${prefix}/tags/${tag}`} style='pill' />
                      </li>
                    ))}
                  </ul>
                  <span class='mt-4 block sm:text-end'>
                    <a aria-label={text.blog.viewAll} href={`${prefix}/tags`} data-astro-prefetch>
                      {text.blog.viewAll} →
                    </a>
                  </span>
                </>
              )}
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>
