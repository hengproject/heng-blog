---
import { getTranslations, type Locale } from '@/i18n'

import PageLayout from '@/layouts/BaseLayout.astro'
import { Button, Icon } from '@/components/user'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const text = getTranslations(locale)
const prefix = locale === 'en' ? '/en' : ''
const homeUrl = prefix || '/'
---

<PageLayout meta={{ title: text.policy.title, description: text.policy.description }}>
  <Button title={text.blog.back} href={homeUrl} style='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='text-3xl font-medium'>{text.policy.title}</h1>
      <p class='mt-3 text-muted-foreground'>{text.policy.description}</p>
    </div>

    <div id='content' class='animate mt-8 border-t border-border pt-6'>
      <a
        href={`${prefix}/terms/policy`}
        class='group flex items-start justify-between gap-6 py-3'
        data-astro-prefetch
      >
        <span>
          <span class='block font-medium group-hover:text-primary'>{text.policy.document}</span>
          <span class='mt-1 block text-sm text-muted-foreground'>
            {text.policy.documentDescription}
          </span>
        </span>
        <Icon name='chevron-down' class='mt-1 size-5 shrink-0 -rotate-90' />
      </a>
    </div>
  </main>
</PageLayout>
