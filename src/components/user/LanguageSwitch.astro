---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, getTranslations } from '@/i18n'
import { getBlogCollection, getBlogCollectionEn, getPostSlug } from '@/server'

import Icon from './Icon.astro'

const locale = getLocale(Astro.currentLocale)
const targetLocale = locale === 'zh' ? 'en' : 'zh'
const text = getTranslations(locale)
const currentPath = Astro.url.pathname

let pagePath = currentPath
if (locale === 'en') {
  pagePath = currentPath === '/en' ? '/' : currentPath.replace(/^\/en(?=\/)/u, '')
}

let targetUrl = getRelativeLocaleUrl(targetLocale, pagePath)
if (targetUrl !== '/' && targetUrl.endsWith('/')) {
  targetUrl = targetUrl.slice(0, -1)
}

let translationAvailable = true
const articleMatch = pagePath.match(/^\/blog\/(.+)$/u)

if (articleMatch) {
  const articleSlug = articleMatch[1]
  const [zhPosts, enPosts] = await Promise.all([getBlogCollection(), getBlogCollectionEn()])
  const zhSlugs = new Set(zhPosts.map(({ id }) => getPostSlug(id)))
  const enSlugs = new Set(enPosts.map(({ id }) => getPostSlug(id)))
  const isArticle = zhSlugs.has(articleSlug) || enSlugs.has(articleSlug)

  if (isArticle) {
    translationAvailable =
      targetLocale === 'en' ? enSlugs.has(articleSlug) : zhSlugs.has(articleSlug)
  }
}

const label = translationAvailable ? text.language.switchTo : text.language.unavailable
---

<button
  id='language-switch-btn'
  class:list={[
    'box-content rounded-md border p-1.5 transition-colors md:group-[.not-top]:rounded-xl',
    translationAvailable ? 'hover:bg-border' : 'cursor-not-allowed opacity-45'
  ]}
  title={label}
  aria-label={label}
  data-target-url={translationAvailable ? targetUrl : undefined}
  disabled={!translationAvailable}
>
  <div class='flex items-center gap-1'>
    <Icon name='earth' class='size-4' />
    <span class='text-xs font-medium'>{text.language.current}</span>
  </div>
</button>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const switchBtn = document.getElementById('language-switch-btn') as HTMLButtonElement | null
    switchBtn?.addEventListener('click', () => {
      const targetUrl = switchBtn.dataset.targetUrl
      if (targetUrl) window.location.href = targetUrl
    })
  })
</script>
