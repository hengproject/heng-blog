---
import { getTranslations, type Locale } from '@/i18n'

import { Icon } from '@/components/user'
import { getReadingTime } from '@/utils/reading-time'
import { getBlogCollection, getBlogCollectionEn, sortMDByDate } from '@/utils/server'
import config from '@/site-config'

interface BlogStatsProps {
  locale: Locale
}

const { locale } = Astro.props as BlogStatsProps
const text = getTranslations(locale)
const localeCode = locale === 'en' ? 'en-US' : 'zh-CN'
const blogStartDate = new Date(`${config.blogStartDate ?? '2026-07-13'}T00:00:00`)

const allPosts = locale === 'en' ? await getBlogCollectionEn() : await getBlogCollection()
const sortedPosts = sortMDByDate(allPosts)

const today = new Date()
const daysDiff = Math.max(
  0,
  Math.floor((today.getTime() - blogStartDate.getTime()) / (1000 * 60 * 60 * 24))
)

const lastUpdated =
  sortedPosts.length > 0
    ? new Date(sortedPosts[0].data.updatedDate || sortedPosts[0].data.publishDate)
    : undefined

let totalWords = 0
for (const post of allPosts) {
  try {
    const { body } = post
    if (body) {
      const readingTime = getReadingTime(body)
      totalWords += readingTime.words
    }
  } catch (error) {
    console.warn(`Error calculating word count for post ${post.id}:`, error)
  }
}

const numberFormatter = new Intl.NumberFormat(localeCode, {
  notation: 'compact',
  maximumFractionDigits: 1
})

const formatDate = (date: Date) => {
  return date.toLocaleDateString(localeCode, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC'
  })
}
---

<div class='flex flex-col gap-y-5'>
  <div class='grid grid-cols-1 gap-4 sm:grid-cols-3'>
    <div
      class='group flex flex-col items-center gap-2 rounded-lg border border-border bg-card p-4 shadow-sm transition-all hover:border-foreground/25 hover:shadow-lg'
    >
      <Icon
        name='time'
        class='size-5 text-muted-foreground transition-colors group-hover:text-primary'
      />
      <div class='text-center'>
        <div class='text-2xl font-bold text-foreground transition-colors group-hover:text-primary'>
          {daysDiff}
        </div>
        <div class='text-sm text-muted-foreground'>{text.home.stats.daysOnline}</div>
      </div>
    </div>

    <div
      class='group flex flex-col items-center gap-2 rounded-lg border border-border bg-card p-4 shadow-sm transition-all hover:border-foreground/25 hover:shadow-lg'
    >
      <Icon
        name='calendar'
        class='size-5 text-muted-foreground transition-colors group-hover:text-primary'
      />
      <div class='text-center'>
        <div class='text-sm font-medium text-foreground transition-colors group-hover:text-primary'>
          {lastUpdated ? formatDate(lastUpdated) : text.home.stats.noPosts}
        </div>
        <div class='text-sm text-muted-foreground'>{text.home.stats.lastUpdated}</div>
      </div>
    </div>

    <div
      class='group flex flex-col items-center gap-2 rounded-lg border border-border bg-card p-4 shadow-sm transition-all hover:border-foreground/25 hover:shadow-lg'
    >
      <Icon
        name='document'
        class='size-5 text-muted-foreground transition-colors group-hover:text-primary'
      />
      <div class='text-center'>
        <div class='text-2xl font-bold text-foreground transition-colors group-hover:text-primary'>
          {numberFormatter.format(totalWords)}
        </div>
        <div class='text-sm text-muted-foreground'>{text.home.stats.totalWords}</div>
      </div>
    </div>
  </div>

  <div class='flex items-center justify-between border-t border-border pt-3 text-sm'>
    <span class='text-muted-foreground'>{text.home.stats.totalPosts}</span>
    <span class='font-medium text-foreground'>{allPosts.length}</span>
  </div>
</div>
