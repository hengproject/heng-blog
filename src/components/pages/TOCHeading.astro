---
import katex from 'katex'

import { cn } from '@/utils'
import { type TocItem } from '@/plugins/toc'

interface Props {
  heading: TocItem
}

const {
  heading: { depth, slug, subheadings, text }
} = Astro.props

function escapeHtml(value: string) {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;')
}

function renderHeadingText(value: string) {
  return value
    .split(/(\$[^$\n]+\$|[A-Za-z][A-Za-z0-9]*(?:[_^]\{[^{}\n]+\})+)/u)
    .map((part) => {
      const delimited = part.startsWith('$') && part.endsWith('$')
      const bareScript = /^[A-Za-z][A-Za-z0-9]*(?:[_^]\{[^{}\n]+\})+$/u.test(part)
      if (!delimited && !bareScript) return escapeHtml(part)

      try {
        return katex.renderToString(delimited ? part.slice(1, -1) : part, {
          displayMode: false,
          output: 'htmlAndMathml',
          throwOnError: true
        })
      } catch {
        return escapeHtml(part)
      }
    })
    .join('')
}

const renderedText = renderHeadingText(text)
---

<li>
  <div class='relative'>
    <span
      class='absolute top-[5%] w-[2px] rounded transition-colors duration-300 [&.highlight-bg]:bg-primary [&.readed]:bg-input'
    ></span>
    <a
      aria-label={`Scroll to section: ${text}`}
      class={cn(
        'line-clamp-2 px-3 py-1 ms-2 flex-1 text-foreground/75 transition-all hover:text-foreground [&.highlight]:font-medium [&.highlight]:text-primary [&.readed]:text-input [&.highlight-bg-translucent]:bg-muted',
        depth === 3 && 'ps-7',
        depth === 4 && 'ps-10',
        depth === 5 && 'ps-14'
      )}
      href={`#${slug}`}><span set:html={renderedText} /></a
    >
  </div>
  {
    !!subheadings.length && (
      <ul>
        {subheadings.map((subheading) => (
          <Astro.self heading={subheading} />
        ))}
      </ul>
    )
  }
</li>
