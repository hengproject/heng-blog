---
import { getEntry } from 'astro:content'
import { getLocale, getLocalizedUrl } from '@/i18n'

import { Icon } from '@/components/user'
import { cn } from '@/utils'

interface Props {
  slug: string
  label?: string
  showDescription?: boolean
  class?: string
}

const { slug, label, showDescription = true, class: className } = Astro.props

const locale = getLocale(Astro.currentLocale)
const normalizedSlug = slug
  .trim()
  .replace(/^\/?(?:en\/)?blog\//, '')
  .replace(/\/$/, '')
const post =
  locale === 'en'
    ? await getEntry('blogEn', normalizedSlug)
    : await getEntry('blog', normalizedSlug)

if (!post) {
  throw new Error(`BlogLink could not find ${locale} post "${normalizedSlug}"`)
}
if (import.meta.env.PROD && post.data.draft) {
  throw new Error(`BlogLink cannot target draft post "${normalizedSlug}" in production`)
}

const href = getLocalizedUrl(locale, `/blog/${post.id}`)
const date = post.data.updatedDate ?? post.data.publishDate
const dateText = new Intl.DateTimeFormat(locale === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
}).format(date)
const linkLabel = label ?? (locale === 'zh' ? '继续阅读' : 'Continue reading')
---

<a
  class={cn(
    'not-prose group my-5 block rounded-lg border border-border bg-card p-4 text-foreground no-underline transition-colors hover:border-primary/40 hover:bg-muted/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring sm:p-5',
    className
  )}
  href={href}
  data-astro-prefetch
>
  <span class='flex items-center justify-between gap-3'>
    <span class='flex items-center gap-2 text-xs font-medium text-primary'>
      <Icon class='size-4' name='link' />
      {linkLabel}
    </span>
    <span
      aria-hidden='true'
      class='text-lg leading-none text-muted-foreground transition-transform group-hover:translate-x-1 group-hover:text-primary'
    >
      →
    </span>
  </span>

  <span class='mt-2 block text-base font-semibold leading-snug sm:text-lg'>{post.data.title}</span>

  {
    showDescription && (
      <span class='mt-1.5 line-clamp-2 block text-sm leading-relaxed text-muted-foreground'>
        {post.data.description}
      </span>
    )
  }

  <span class='mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-muted-foreground'>
    {post.data.draft && <span class='font-medium text-red-500'>Draft</span>}
    {post.data.category && <span>{post.data.category}</span>}
    {post.data.category && <span aria-hidden='true'>·</span>}
    <time datetime={date.toISOString()}>{dateText}</time>
  </span>
</a>
