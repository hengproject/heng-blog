---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'

// Plugin styles
import 'katex/dist/katex.min.css'

import { getPostCollectionContext } from '@/server'

import PageLayout from '@/layouts/ContentLayout.astro'
import { Comment, MediumZoom } from '@/components/advanced'
import { ArticleBottom, Copyright, Hero, TOC } from '@/components/pages'
import CollectionNavigator from '@/components/pages/CollectionNavigator.astro'
import { integ } from '@/site-config'

interface Props {
  post: CollectionEntry<'blog'> | CollectionEntry<'blogEn'>
  posts: CollectionEntry<'blog'>[] | CollectionEntry<'blogEn'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
  locale: 'zh' | 'en'
}

const {
  post: { id, data },
  posts,
  headings,
  remarkPluginFrontmatter,
  locale
} = Astro.props

const {
  description,
  heroImage,
  publishDate,
  title,
  updatedDate,
  draft: isDraft,
  comment: enableComment
} = data

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : '/images/social-card.svg'
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const primaryColor = data.heroImage?.color ?? 'hsl(var(--primary) / var(--tw-text-opacity))'
const postCollection = await getPostCollectionContext(id, posts, locale)
---

<PageLayout
  meta={{ articleDate, description, ogImage: socialImage, title }}
  highlightColor={primaryColor}
>
  {!!headings.length && <TOC {headings} slot='sidebar' />}

  <Fragment slot='header'>
    <Hero {data} {remarkPluginFrontmatter} />
    {postCollection && <CollectionNavigator collection={postCollection} {locale} />}
  </Fragment>

  <slot />

  <Fragment slot='bottom'>
    {/* Copyright */}
    <Copyright {data} />
    {/* Article recommend */}
    <ArticleBottom collections={posts} {id} class='mt-3 sm:mt-6' />
    {/* Comment */}
    {integ.waline.enable && !isDraft && enableComment && <Comment class='mt-3 sm:mt-6' />}
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{integ.mediumZoom.enable && <MediumZoom />}
