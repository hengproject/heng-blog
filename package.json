{
  "name": "blog-starter",
  "type": "module",
  "version": "0.0.2",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "astro dev",
    "dev:check": "astro check --watch & astro dev",
    "new:post": "node src/scripts/index.js new",
    "build": "astro check && astro build",
    "build:cloudflare": "astro check && astro build",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check",
    "astro": "astro",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,md,mdx,astro}'",
    "lint": "eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "lint:check": "eslint 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "test:e2e": "playwright test",
    "type:check": "astro check",
    "quality": "npm run lint && npm run sync && npm run type:check && npm run format",
    "yijiansilian": "npm run quality",
    "clean": "rm -rf .astro dist .wrangler",
    "clean:all": "npm run clean && rm -rf node_modules"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "4.3.12",
    "@astrojs/rss": "4.0.14",
    "@astrojs/sitemap": "3.6.0",
    "@astrojs/tailwind": "6.0.2",
    "@astrojs/upgrade": "^0.6.2",
    "@pagefind/default-ui": "^1.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@waline/client": "^3.8.0",
    "astro": "5.16.4",
    "caniuse-lite": "^1.0.30001759",
    "date-fns": "^4.1.0",
    "hast-util-select": "^6.0.4",
    "katex": "^0.16.25",
    "node-html-parser": "^7.0.1",
    "pagefind": "^1.4.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.33.5",
    "simple-icons": "^15.22.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.53.3"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^6.3.9",
